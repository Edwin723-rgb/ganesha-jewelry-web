{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "framework": null,
  "rewrites": [
    {
      "source": "/collections/:slug",
      "destination": "/"
    },
    {
      "source": "/collections/:slug/",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/ganesha_assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
